PORT=4000
DATABASE_URL="mysql://user:password@localhost:3306/chat_support"
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"

# CORS - comma separated list of allowed origins (admin dashboard + storefronts)
CORS_ORIGINS="http://localhost:5173"

# Public URL this backend is reachable at (used when registering the ScriptTag)
BACKEND_PUBLIC_URL="http://localhost:4000"

# SMTP settings used to email admins when a conversation needs a human
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS="change-me"
MAIL_FROM="Support Bot <support@example.com>"

# Bootstrap super admin, created automatically on first boot if no admins exist
BOOTSTRAP_SUPER_ADMIN_EMAIL="owner@example.com"
BOOTSTRAP_SUPER_ADMIN_PASSWORD="change-me-now"
BOOTSTRAP_SUPER_ADMIN_NAME="Owner"
